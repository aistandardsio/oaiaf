@startuml
title A2A Agent-to-Agent Delegation

participant "Human User" as user
participant "Orchestrator Agent" as orchestrator
participant "Specialist Agent" as specialist
participant "Authorization Server" as auth_server
participant "Resource Server" as resource_server


== Agent Discovery ==
user -> orchestrator: Review PR #123 for security issues
orchestrator -> specialist: GET /.well-known/agent.json
specialist --> orchestrator: Agent Card
{capabilities: [security-scan],
endpoints, auth}

== Task Delegation ==
orchestrator -> auth_server: POST /token
grant_type=delegation
delegate_to={specialist_id}
scope=security-scan:pr-123
auth_server -> auth_server: Validate:
- Orchestrator can delegate
- Scope is subset
- Specialist registered
auth_server --> orchestrator: Delegation Token
{sub: specialist, act: [{orchestrator}, {user}]}

== Task Execution ==
orchestrator -> specialist: POST /invoke
{task: security-scan, target: pr-123}
Authorization: Bearer {delegation_token}
specialist -> resource_server: GET /repos/acme/backend/pulls/123/files
Authorization: Bearer {delegation_token}
resource_server -> resource_server: Validate delegation chain
Log: user -> orchestrator -> specialist
resource_server --> specialist: 200 OK
{files: [...]}
specialist -> specialist: Security Analysis

== Task Completion ==
specialist --> orchestrator: 200 OK
{findings: [...], risk_level: medium}
orchestrator --> user: Security Review Complete
2 vulnerabilities found

@enduml
